---
import PulseMark from "./PulseMark.astro";
---
<section class="section py-32">
  <div
    class="glass-card flex flex-col items-center p-16 text-center ring-cy-300/15"
    style="background: radial-gradient(120% 120% at 50% 0%, #1A2A35 0%, #0E1014 70%);"
  >
    <PulseMark size={72} />
    <h2 class="heading-lg mt-8 max-w-[860px]">
      Stop hovering. <span class="gradient-text">Let your agents page you.</span>
    </h2>
    <p class="mt-4 max-w-[600px] text-[17px] leading-[1.55] text-mute-fg">
      Free, local-first, open source. Apache 2.0.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3.5">
      <a
        href="https://github.com/riot-io-pty-ltd/page"
        class="inline-flex items-center gap-2 rounded-full gradient-bg px-7 py-3.5 text-[15px] font-extrabold text-ink-950"
      >
        Get started <span aria-hidden="true">→</span>
      </a>
      <a
        href="https://github.com/riot-io-pty-ltd/page"
        class="inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-[15px] font-semibold ring-1 ring-white/20 hover:ring-white/40 transition"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>
