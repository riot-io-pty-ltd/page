---
import PulseMark from "./PulseMark.astro";
---
<footer class="border-t border-white/[0.04] bg-ink-950">
  <div class="section flex flex-wrap items-center justify-between gap-y-3 py-7">
    <div class="flex items-center gap-2 text-[13px]">
      <PulseMark size={18} animate={false} />
      <span class="font-bold">Page</span>
      <span class="text-mute-dim">·</span>
      <span class="text-mute-fg">the on-call interface for AI coding agents</span>
    </div>
    <p class="text-[12px] font-medium text-mute-dim">
      © 2026 · Apache 2.0 · <a class="underline-offset-2 hover:underline" href="https://github.com/riot-io-pty-ltd/page">GitHub</a>
    </p>
  </div>
</footer>
