<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Lets Page send Apple Events to other apps (Terminal, System Events).
         Required under hardened runtime — without this entitlement the OS
         won't even prompt for permission, it just denies. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
